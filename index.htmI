<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clinical Calculator (BSA, CrCl, Dose & Carboplatin)</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body { font-family: 'Helvetica Neue', Arial, sans-serif; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen py-8 px-4">

    <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-xl overflow-hidden">
        
        <div class="bg-gradient-to-r from-blue-600 to-teal-500 p-6 text-white text-center">
            <h1 class="text-2xl md:text-3xl font-bold">เครื่องคำนวณทางเภสัชกรรม</h1>
            <p class="text-blue-100 mt-2 text-sm md:text-base">คำนวณ CrCl, BSA, Dose Adjustment และ Carboplatin (Calvert Formula)</p>
        </div>

        <div class="p-6 md:p-8 space-y-8">
            
            <div class="bg-gray-50 p-5 rounded-xl border border-gray-200">
                <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b pb-2 flex items-center gap-2">
                    <span class="bg-blue-500 text-white rounded-full w-6 h-6 inline-flex items-center justify-center text-sm">1</span>
                    ข้อมูลผู้ป่วยพื้นฐาน
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">เพศ</label>
                        <select id="gender" class="w-full border rounded-lg p-2.5 bg-white focus:ring-2 focus:ring-blue-500" oninput="calculateAll()">
                            <option value="male">ชาย (Male)</option>
                            <option value="female">หญิง (Female)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">อายุ (ปี)</label>
                        <input type="number" id="age" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500" placeholder="เช่น 60" oninput="calculateAll()">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">น้ำหนัก (kg)</label>
                        <input type="number" id="weight" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500" placeholder="เช่น 65" oninput="calculateAll()">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">ส่วนสูง (cm)</label>
                        <input type="number" id="height" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500" placeholder="เช่น 170" oninput="calculateAll()">
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mt-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Scr (mg/dL)</label>
                        <input type="number" step="0.01" id="scr" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500" placeholder="เช่น 1.2" oninput="calculateAll()">
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-blue-50 border border-blue-200 p-5 rounded-xl text-center">
                    <p class="text-sm font-semibold text-blue-800 uppercase tracking-wider">Body Surface Area (BSA)</p>
                    <p class="text-3xl font-bold text-blue-900 mt-2"><span id="res-bsa">-</span> <span class="text-lg font-normal">m²</span></p>
                    <p class="text-xs text-blue-600 mt-1">(คำนวณด้วยสูตร DuBois)</p>
                </div>
                <div class="bg-teal-50 border border-teal-200 p-5 rounded-xl text-center">
                    <p class="text-sm font-semibold text-teal-800 uppercase tracking-wider">Creatinine Clearance (CrCl)</p>
                    <p class="text-3xl font-bold text-teal-900 mt-2"><span id="res-crcl">-</span> <span class="text-lg font-normal">mL/min</span></p>
                    <p class="text-xs text-teal-600 mt-1">(คำนวณด้วยสูตร Cockcroft-Gault)</p>
                </div>
            </div>

            <hr class="border-gray-200">

            <div class="bg-gray-50 p-5 rounded-xl border border-gray-200">
                <h2 class="text-lg font-semibold text-gray-800 mb-4 border-b pb-2 flex items-center gap-2">
                    <span class="bg-blue-500 text-white rounded-full w-6 h-6 inline-flex items-center justify-center text-sm">2</span>
                    การคำนวณขนาดยา (BSA-based & Dose Adjustment)
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-4">
                        <h3 class="font-medium text-sm text-gray-500 uppercase">ขนาดยาที่คำนวณตามสูตร (Calculated)</h3>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">ขนาดยาที่ต้องการให้ต่อพื้นที่ผิว (mg/m²)</label>
                            <input type="number" id="regimen-dose" class="w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-blue-500" placeholder="เช่น 175" oninput="calculateDose()">
                        </div>
                        <div class="p-4 bg-white rounded-lg border border-gray-200">
                            <p class="text-sm text-gray-600">ขนาดยาที่ควรได้รับจริงตามทฤษฎี:</p>
                            <p class="text-xl font-bold text-gray-800 mt-1"><span id="target-dose">-</span> mg</p>
                        </div>
                    </div>

                    <div class="space-y-4 border-t md:border-t-0 md:border-l md:pl-6 border-gray-200">
                        <h3 class="font-medium text-sm text-gray-500 uppercase">ขนาดยาที่สั่งจ่ายจริง (Actual Administered)</h3>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">ขนาดยาที่ให้จริง (Actual Dose ในกล่อง/ที่ผสมจริง) (mg)</label>
                            <input type="number" id="actual-dose" class="w-full border rounded-lg p-2.5 bg-yellow-50 border-yellow-300 focus:ring-2 focus:ring-yellow-500" placeholder="เช่น 300" oninput="calculateDose()">
                        </div>
                        
                        <div class="grid grid-cols-2 gap-2">
                            <div class="p-3 bg-gray-100 rounded-lg">
                                <p class="text-xs text-gray-500">คิดเป็น mg/m² จริง:</p>
                                <p class="text-base font-semibold text-gray-800 mt-0.5"><span id="actual-mg-m2">-</span> mg/m²</p>
                            </div>
                            <div class="p-3 bg-gray-100 rounded-lg">
                                <p class="text-xs text-gray-500">% ความต่างของโดส:</p>
                                <p class="text-base font-semibold mt-0.5" id="dose-diff-wrapper"><span id="dose-diff">-</span> %</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="border-gray-200">

            <div class="bg-amber-50 p-5 rounded-xl border border-amber-200">
                <h2 class="text-lg font-semibold text-amber-900 mb-4 border-b border-amber-200 pb-2 flex items-center gap-2">
                    <span class="bg-amber-600 text-white rounded-full w-6 h-6 inline-flex items-center justify-center text-sm">3</span>
                    สำหรับยา Carboplatin โดยเฉพาะ (Calvert Formula)
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-amber-900 mb-1">Target AUC ที่ต้องการ</label>
                        <input type="number" step="0.5" id="target-auc" class="w-full border border-amber-300 rounded-lg p-2.5 focus:ring-2 focus:ring-amber-500 bg-white" placeholder="เช่น 5 หรือ 6" oninput="calculateCarboplatin()">
                        <p class="text-xs text-amber-700 mt-1">*สูตรคำนวณ: Dose (mg) = Target AUC × (GFR + 25) <br> (ในที่นี้ใช้ค่า CrCl แทน GFR โดยจำกัดค่าสูงสุดไม่เกิน 125 mL/min)</p>
                    </div>
                    <div class="flex flex-col justify-center items-center bg-white p-4 rounded-xl border border-amber-200 shadow-sm">
                        <p class="text-sm font-semibold text-amber-800 uppercase tracking-wider">Carboplatin Dose ที่ต้องให้</p>
                        <p class="text-3xl font-bold text-amber-600 mt-2"><span id="res-carboplatin">-</span> <span class="text-lg font-normal">mg</span></p>
                    </div>
                </div>
            </div>

        </div>
        
        <div class="bg-gray-100 p-4 text-center text-xs text-gray-500 border-t border-gray-200">
            พัฒนาขึ้นเพื่อความสะดวกในการคำนวณเบื้องต้น โปรดรีเช็กความถูกต้องตามหลักการแพทย์อีกครั้งก่อนใช้งานจริง
        </div>
    </div>

    <script>
        function calculateAll() {
            // ดึงค่าจากฟอร์มพื้นฐาน
            const gender = document.getElementById('gender').value;
            const age = parseFloat(document.getElementById('age').value);
            const weight = parseFloat(document.getElementById('weight').value);
            const height = parseFloat(document.getElementById('height').value);
            const scr = parseFloat(document.getElementById('scr').value);

            let bsa = 0;
            let crcl = 0;

            // 1. คำนวณ BSA (DuBois formula: BSA = 0.007184 × W^0.425 × H^0.725)
            if (weight > 0 && height > 0) {
                bsa = 0.007184 * Math.pow(weight, 0.425) * Math.pow(height, 0.725);
                document.getElementById('res-bsa').innerText = bsa.toFixed(2);
            } else {
                document.getElementById('res-bsa').innerText = "-";
            }

            // 2. คำนวณ CrCl (Cockcroft-Gault)
            if (age > 0 && weight > 0 && scr > 0) {
                crcl = ((140 - age) * weight) / (72 * scr);
                if (gender === 'female') {
                    crcl *= 0.85;
                }
                document.getElementById('res-crcl').innerText = crcl.toFixed(1);
            } else {
                document.getElementById('res-crcl').innerText = "-";
            }

            // รันฟังก์ชันคำนวณในส่วนที่เหลือต่อพ่วงไปด้วยกัน
            calculateDose(bsa);
            calculateCarboplatin(crcl);
        }

        function calculateDose(passedBsa) {
            // ถ้ารันแยก ให้ดึงค่า BSA ใหม่
            let bsa = passedBsa;
            if (!bsa) {
                const weight = parseFloat(document.getElementById('weight').value);
                const height = parseFloat(document.getElementById('height').value);
                if (weight > 0 && height > 0) {
                    bsa = 0.007184 * Math.pow(weight, 0.425) * Math.pow(height, 0.725);
                }
            }

            const regimenDose = parseFloat(document.getElementById('regimen-dose').value);
            const actualDose = parseFloat(document.getElementById('actual-dose').value);

            let targetDose = 0;

            // คำนวณหา Target Dose ตามพื้นที่ผิว
            if (bsa > 0 && regimenDose > 0) {
                targetDose = regimenDose * bsa;
                document.getElementById('target-dose').innerText = targetDose.toFixed(1);
            } else {
                document.getElementById('target-dose').innerText = "-";
            }

            // คำนวณ Actual mg/m2 และ % ความต่าง
            if (bsa > 0 && actualDose > 0) {
                const actualMgM2 = actualDose / bsa;
                document.getElementById('actual-mg-m2').innerText = actualMgM2.toFixed(1);

                if (targetDose > 0) {
                    // สูตรคำนวณ %ความต่าง: ((Actual - Target) / Target) * 100
                    const diffPercent = ((actualDose - targetDose) / targetDose) * 100;
                    const diffText = (diffPercent >= 0 ? "+" : "") + diffPercent.toFixed(1);
                    
                    const wrapper = document.getElementById('dose-diff-wrapper');
                    document.getElementById('dose-diff').innerText = diffText;

                    // ถ้าต่างกันเกิน +/- 10% ให้แสดงสีแดงเตือนความเบี่ยงเบน
                    if (Math.abs(diffPercent) > 10) {
                        wrapper.className = "text-base font-semibold mt-0.5 text-red-600";
                    } else {
                        wrapper.className = "text-base font-semibold mt-0.5 text-green-600";
                    }
                }
            } else {
                document.getElementById('actual-mg-m2').innerText = "-";
                document.getElementById('dose-diff').innerText = "-";
                document.getElementById('dose-diff-wrapper').className = "text-base font-semibold mt-0.5 text-gray-800";
            }
        }

        function calculateCarboplatin(passedCrcl) {
            let crcl = passedCrcl;
            if (crcl === undefined) {
                const gender = document.getElementById('gender').value;
                const age = parseFloat(document.getElementById('age').value);
                const weight = parseFloat(document.getElementById('weight').value);
                const scr = parseFloat(document.getElementById('scr').value);
                if (age > 0 && weight > 0 && scr > 0) {
                    crcl = ((140 - age) * weight) / (72 * scr);
                    if (gender === 'female') crcl *= 0.85;
                }
            }

            const targetAuc = parseFloat(document.getElementById('target-auc').value);

            if (crcl > 0 && targetAuc > 0) {
                // ตามแนวทางสากล (FDA) Cap ค่า GFR (CrCl) ไว้ไม่เกิน 125 mL/min เพื่อป้องกัน Overdose ในคนที่ไตทำงานดีมากๆ
                const cappedCrcl = Math.min(crcl, 125);
                const carboDose = targetAuc * (cappedCrcl + 25);
                document.getElementById('res-carboplatin').innerText = Math.round(carboDose);
            } else {
                document.getElementById('res-carboplatin').innerText = "-";
            }
        }
    </script>
</body>
</html>
